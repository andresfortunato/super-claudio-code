{
  "hooks": {
    "SessionStart": [
      {
        "matcher": null,
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/session-start.js",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": null,
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/user-prompt-submit.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": null,
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/context-monitor.js",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": null,
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/task-completed.js",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": null,
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/stop.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": null,
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/pre-compact.js",
            "timeout": 5
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": null,
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/teammate-idle.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
